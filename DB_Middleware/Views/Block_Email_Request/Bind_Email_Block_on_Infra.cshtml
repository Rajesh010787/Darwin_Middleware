                                        // Ensure UserUniqueID exists in the row data
                                        if (row.userUniqueID) {
                                            return '<a style="text-decoration: none; color:black;" href="#"  onclick=\'javascript:BindDataForremoveemailid("' + row.userUniqueID + '"); \'><span class="badge badge-pill badge-success">Update</span></a>';
                                        } else {
