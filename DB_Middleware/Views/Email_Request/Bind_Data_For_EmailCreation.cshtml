        function BindEmpdetailsforemail(paageCid) {
            $.ajax({
                url: "/Email_Request/get_pending_employee_emailid_creation",
                type: "GET",
                data: {
                    UniqueID: paageCid
                },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    if (Array.isArray(data) && data.length > 0) {
                        // Destroy the existing DataTable instance if it exists
                        if ($.fn.DataTable.isDataTable('#example1')) {
                            $('#example1').DataTable().clear().destroy();
                        }
                        // Initialize DataTable with new data
                        $('#example1').DataTable({
                            responsive: true,
                            processing: true,
                            data: data,
                            order: [[4, 'desc']],
                            columns: [
                                {
                                    data: null,
                                    title: 'Action',
                                    render: function (data, type, row) {
                                        // Ensure UserUniqueID exists in the row data
                                        if (row.userUniqueID) {
                                            return `
                                       <a style="text-decoration: none; color:black;"
                                           href="#"
                                           onclick='Redirect("${row.userUniqueID}", "${row.cStatus}");'>
                                            <span class="badge badge-pill badge-success">Validate</span>
                                        </a>

                                        <a style="text-decoration: none; color:black;" 
                                           href="#"     onclick='Bind_Records_For_NotJoined("${row.userUniqueID}");'>
                                          
                                         <span class="badge badge-pill badge-danger ">Not Joined</span>
                                        </a> `;
                                        } else {
                                            return '<span></span>'; // Fallback if UserUniqueID is not present
                                        }
                                    }
                                },
                                { data: 'fname', title: 'First Name' },
                                { data: 'mname', title: 'Middle Name' },
                                { data: 'lname', title: 'Last Name' },
                                { data: 'date_of_joining', title: 'Date of Joining', type: 'date' },
                                { data: 'group_company', title: 'Group Company' },
                                { data: 'department_cost_center_name', title: 'Cost Center Name' },
                                
