                            /* console.log('Edit button clicked for ID: ' + id);*/
                        });
                    } else {
                        console.error("No data found or data is not an array");
                    }
                },
                error: function (xhr, status, error) {
                    console.error("AJAX Error: ", status, error);
                }
            });
        }

        //----------------------------------Bind Tracking History -------------------------------------------------
        function getdaterecords() {
            // Get the values from the input fields
            var date1 = $("#txtextenddbdoj").val();  // The first date
            var date2 = $("#txtconfrimjoiningdate").val();  // The second date

            // Convert the dates to Date objects
            var date1Parts = date1.split('-');  // Split the date (dd-mm-yy) into day, month, year
            var date2Parts = date2.split('-');  // Same for the second date

            // Format them as YYYY-MM-DD for proper comparison
            var formattedDate1 = new Date(date1Parts[2], date1Parts[1] - 1, date1Parts[0]); // new Date(year, month-1, day)
            var formattedDate2 = new Date(date2Parts[2], date2Parts[1] - 1, date2Parts[0]);

            // Check if the second date is earlier or not after the first date
            if (formattedDate2 <= formattedDate1) {
                alert("Please select a date after Darwin DOJ.");
                $("#txtconfrimjoiningdate").val('');  // Clear the input if invalid
            }
        }
