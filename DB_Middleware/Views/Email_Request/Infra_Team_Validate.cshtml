    <script type='text/javascript'>

        var date = new Date();
        var year = date.getFullYear(); //get year
        var month = date.getMonth(); //get month
        var controls = {
            leftArrow: '<i class="fal fa-angle-left" style="font-size: 1.25rem"></i>',
            rightArrow: '<i class="fal fa-angle-right" style="font-size: 1.25rem"></i>'
        }
        var runDatePicker = function () {

            $("#txttilldate").datepicker({
                startDate: new Date(year, month, '01'), //set it here

                autoclose: true

            });
        }
        var totalList = [];
        var iterms = "";
        $(document).ready(function () {
            const urlSearchParams = new URLSearchParams(window.location.search);
            const params = Object.fromEntries(urlSearchParams.entries());
            var cid = params['id'];
            $('.select2').select2();
            BindpendingempEmpdetails(cid);
            
            document.getElementById("txtconfirmjoiningdate").style.display = "none";
            //Binddomainname();
            //runDatePicker();
            //Bindgroupemail();
            BindMSLicense();

        });
        function Bindeditgroupemail(groupemails) {
            var groupemail = new Array();
            // This will return an array with strings "1", "2", etc.
            groupemail = groupemails.split(",");
            $.ajax({

                url: "/Bind_Master/Bind_GEmail",
                type: "GET",
                async: false,
                data: { Groupcompanyname: $("#txtbusinessvertical").val(), Cost_Center_Name: $("#txtdivision").val() },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    var JsData = data;
                    var binddata = '<option value="">Select</option>';
                    for (var index = 0; index < JsData.length; index++) {
                        binddata = binddata + '<option value="' + JsData[index].groupemailids + '" >' + JsData[index].groupemailids + '</option>';
                    }
                    $("#dbchoosegroup").html(binddata);
                   
                    $("#dbchoosegroup").val(groupemail);
                }
            });
        }

        function hideDiverepemployee(getvalue) {

            if (getvalue == "Against Replacement Of Left Employee (OLD position)") {

                document.getElementById("div3").style.display = "block";
                document.getElementById("div1").style.display = "block";
                document.getElementById("div2").style.display = "block";
                document.getElementById("div4").style.display = "block";
                document.getElementById("div5").style.display = "block";

            } else {
                $("#txtreplaceecode").val('');
                $("#txtrepemployeename").val('');
                $("#txtrepdesignation").val('');
                $("#txtrepgradelevel").val('');
                $("#txtexicitingemail").val('');
                document.getElementById("div3").style.display = "none";
                document.getElementById("div1").style.display = "none";
                document.getElementById("div2").style.display = "none";
                document.getElementById("div4").style.display = "none";
                document.getElementById("div5").style.display = "none";

            }
        }
        function hidetilldate(getvalue) {

            if (getvalue == "Temprarory") {

                document.getElementById("tilldate").style.display = "block";

            } else {

                document.getElementById("tilldate").style.display = "none";

            }
        }
        function BindpendingempEmpdetails(paageCid) {

            $.ajax({

                url: "/Email_Request/HR_Validate",
                type: "GET",
                data: { UniqueID: "" + paageCid + "" },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                async: false,
                success: function (data) {

                    var build_table = '';
                    for (var index = 0; index < data.length; index++) {


                        $("#fname").val(data[index].fname);
                        $("#Mname").val(data[index].mname);
                        $("#Lname").val(data[index].lname);
                        $("#txtdepartment").val(data[index].department);
                        $("#txtdesignation").val(data[index].deisgnation);
                        $("#txtgrade").val(data[index].level_Grade);
                        $("#txtrm").val(data[index].direct_manager_name);
                        $("#txtrmemail").val(data[index].direct_manager_email);
                        $("#txtlocation").val(data[index].office_location);
                        $("#txtbusinessvertical").val(data[index].group_company);
                        $("#txtdivision").val(data[index].department_cost_center_name);
                        $("#txtmobilenumber").val(data[index].personal_mobile_no);

                        $("#dbpositiontype").val(data[index].hR_Position_Type);
                        if (data[index].hR_Access_Domain_Email == "Only Domain ID") { $("#defaultInline1Radio").prop('checked', true); }
                        if (data[index].hR_Access_Domain_Email == "For Internal Communication") { $("#defaultInline2Radio").prop('checked', true); }
                        if (data[index].hR_Access_Domain_Email == "For Internal / External Communication") { $("#defaultInline4Radio").prop('checked', true); }

                        $("#txtproposedemail").val(data[index].hR_Proposed_Emailid);
                        
                        $("#txthrremark").val(data[index].hrremark);
                        $("#txtdomainname").val(data[index].hR_Chosse_Domain);
                        $("#txtreplaceecode").val(data[index].hR_Emp_Being_Replace_Ecode);
                        $("#txtrepemployeename").val(data[index].hR_Replace_Name);
                        $("#txtexicitingemail").val(data[index].hR_Replace_Email);

                        $("#txtrepdesignation").val(data[index].hR_Replace_Designation);
                        $("#txtrepgradelevel").val(data[index].hR_Replace_Grade);
                        $("#txtjoiningdate").val(data[index].date_of_joining);
                        
                        if ((data[index].group_company == "SMIT") && (data[index].department_cost_center_name == "SMIT Pune")) {
                       
                            document.getElementById("divsmitengin").style.display = "block";
                            $("#txtsmitsubdepart").val(data[index].smitsubdepart);
                            
                        } else {

                            document.getElementById("divsmitengin").style.display = "none";
                            $("#txtsmitsubdepart").val(data[index].smitsubdepart);
                        }
                        $("#txtconfrimjoiningdate").val(data[index].confrimJoiningdate);
                       
                        hideDiverepemployee(data[index].hR_Position_Type);
                       
                        Bindeditgroupemail(data[index].hR_Access_Required_Group);
                        $("#dbchooseemptype").val(data[index].hR_Employee_Type);
                        hidetilldate(data[index].hR_Employee_Type);
                        $("#txttilldate").val(data[index].hR_Till_Date);
           
                        Binddomainname(data[index].hR_Chosse_Domain);

                    }
                }
            });
        }


