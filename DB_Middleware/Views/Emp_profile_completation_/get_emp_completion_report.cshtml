function exportEmployeeExcel(plant) {

    $('#loader').show();

    $.ajax({

        url: '@Url.Action("GetPlantWiseDetailsExport", "Emp_profile_completation_")',
        type: 'GET',
        data: { plant: plant },

        success: function (response) {

            $('#loader').hide();

            var allData = response;

            if (!allData || allData.length === 0) {
                alert("No employee data found.");
                return;
            }

            /* ===========================
               FIELD KEYS FROM API
            ============================ */
            var fields = [
                'employeeId', 'employeeName', 'getentry', 'fatherName',

                'dateOfJoining', 'groupDateOfJoining', 'gender',
                'groupCompany', 'departmentCostCenterName',
                'functionalAreaDept', 'functionalAreaSubDept', 'departmentName',
                'jobLevel', 'levelGrade', 'employeeType',

                'directManagerId', 'directManagerName',
                'hodId', 'hodName',

                'maritalStatus',
                'companyEmail', 'officeMobile', 'personalEmail', 'personalMobile',
                'emergencyContact', 'emergencyPerson',

                'currentAddress', 'permanentAddress',

                'uanNumber', 'bloodGroup',
                'bankName', 'bankBranch', 'bankIFSC', 'bankAccount',

                // Education
                'institutionName', 'levelOfStudy', 'fieldOfStudy',
                'gpaPercentage',

                // Work
                'workCompany', 'workTitle', 'workLocation',
                'workFromDate', 'workToDate',

                // Completion %
                'basicPercent', 'educationPercent', 'workPercent', 'overall'
            ];

            /* ===========================
               EXCEL COLUMN HEADERS
            ============================ */
            var headers = [
                'Sr No', // <--- added serial number column

                'Employee ID', 'Employee Name', 'Entry Route', 'Father Name',

                'Date of Joining', 'Group Date of Joining', 'Gender',
                'Group Company', 'Department Cost Center',
                'Functional Area Dept', 'Functional Area Sub Dept', 'Department Name',
                'Job Level', 'Level Grade', 'Employee Type',

                'Direct Manager ID', 'Direct Manager Name',
                'HOD ID', 'HOD Name',

                'Marital Status',
                'Company Email', 'Office Mobile', 'Personal Email', 'Personal Mobile',
                'Emergency Contact', 'Emergency Person',

                'Current Address', 'Permanent Address',

                'UAN Number', 'Blood Group',
                'Bank Name', 'Bank Branch', 'Bank IFSC', 'Bank Account',

                // Education
                'Education - Institution', 'Education - Level',
                'Education - Field', 'Education - GPA %',

                // Work
                'Work - Company', 'Work - Title', 'Work - Location',
                'Work - From', 'Work - To',

                // Completion %
                'Basic %', 'Education %', 'Work %', 'Overall %'
            ];

            /* ===========================
               MAP DATA WITH SR NO
            ============================ */
            var tableData = allData.map(function (item, index) {
                return [
                    index + 1, // <--- Serial number (Sr No)
                    ...fields.map(function (field) {
                        return item[field] ?? '';
                    })
                ];
            });

            var worksheetData = [headers, ...tableData];

            /* ===========================
               CREATE & EXPORT EXCEL
            ============================ */
            var worksheet = XLSX.utils.aoa_to_sheet(worksheetData);
            var workbook = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(workbook, worksheet, "Employees");

            XLSX.writeFile(workbook, "Employee_Full_Details.xlsx");
        },

        error: function () {
            $('#loader').hide();
            alert("Error exporting Excel.");
        }
    });
}



