// Escape unsafe HTML
function escapeHtml(json) {
    return json.replace(/&/g, "&amp;")
               .replace(/</g, "&lt;")
               .replace(/>/g, "&gt;")
               .replace(/"/g, "&quot;")
               .replace(/'/g, "&#39;")
               .replace(/\n/g, " ");
}

/* =========================
Global Modal Instances
========================= */
let plantModalInstance = null;
let empDetailsModalInstance = null;

/* =========================
Show Plant Details Modal
========================= */
function showPlantDetails(plantName) {

    $('#plantDetailsLabel').text('Plant Details - ' + plantName);
    $('#plantDetailsBody').html('<div class="text-center"><i class="fal fa-spinner fa-spin fs-xxl"></i> Loading...</div>');

    const modalEl = document.getElementById('plantDetailsModal');
    plantModalInstance = new bootstrap.Modal(modalEl, {
        backdrop: 'static',
        keyboard: false
    });

    plantModalInstance.show();

    $.ajax({
        url: '@Url.Action("GetPlantWiseDetails", "Emp_profile_completation_")',
        type: 'GET',
        data: { plant: plantName },
        success: function (data) {

            if (!data || data.length === 0) {
                $('#plantDetailsBody').html('<p class="text-danger text-center">No data available for this plant.</p>');
                return;
            }

            let html = `
                <div style="overflow-x:auto; max-height:70vh;">
                <table id="plantDetailsTable" class="table table-bordered table-striped table-hover text-center" style="width: 100%;">
                    <thead class="bg-primary text-white fw-bold">
                        <tr>
                            <th>Employee Name</th>
                            <th>Group Company</th>
                            <th>Business Unit</th>
                            <th>Basic %</th>
                            <th>Education %</th>
                            <th>Work %</th>
                            <th>Overall %</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>`;

            data.forEach(emp => {
                html += `
                    <tr>
                        <td>${emp.employeeName}</td>
                        <td>${emp.groupCompany}</td>
                        <td>${emp.businessUnit}</td>
                        <td>${emp.basicPercent}%</td>
                        <td>${emp.educationPercent}%</td>
                        <td>${emp.workPercent}%</td>
                        <td><b>${emp.overall}%</b></td>
                        <td>
                            <button class="btn btn-info btn-sm view-emp-details"
                                data-emp='${escapeHtml(JSON.stringify(emp))}'>
                                View
                            </button>
                        </td>
                    </tr>`;
            });

            html += `</tbody></table></div>`;
            $('#plantDetailsBody').html(html);

            // ⭐ Delay initialization so columns are calculated correctly
            setTimeout(function () {
                $('#plantDetailsTable').DataTable({
                    paging: true,
                    searching: true,
                    info: true,
                    scrollY: '50vh',
                    scrollX: true,
                    scrollCollapse: true,
                    fixedHeader: true,

                    dom: 'Bfrtip',
                    buttons: [
                        {
                            extend: 'excel',
                            className: 'btn btn-success btn-sm',
                            text: 'Export All to Excel',
                            action: function () {
                                exportEmployeeExcel(plantName);
                            }
                        }
                    ]
                });
            }, 150);

            // ⭐ Adjust columns when modal is visible
            modalEl.addEventListener('shown.bs.modal', function () {
                let table = $('#plantDetailsTable').DataTable();
                table.columns.adjust().draw();
            });
        },

        error: function (err) {
            console.error('Error fetching plant details:', err);
            $('#plantDetailsBody').html('<p class="text-danger">Error loading plant details.</p>');
        }
    });
}




/* =========================
Close Plant Modal
========================= */
document.getElementById('closeModalBtn').addEventListener('click', function () {
    if (plantModalInstance) plantModalInstance.hide();
});

