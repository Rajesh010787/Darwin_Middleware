    //-------------------------------------------plant wise graph ------------------------------
function get_dashboard_first_plant_wiese() {

    let plant = [];
    for (let option of document.getElementById("dbplant").options) {
        if (option.selected) plant.push(option.value);
    }

    $.ajax({
        url: '@Url.Action("GetChartDataPlant", "Emp_profile_completation_")',
        type: 'GET',
        data: { plants: plant.toString().trim() },
        contentType: "application/json; charset=utf-8",

        success: function (data) {

            const chartData = data.series[0].data;

            const labels = chartData.map(d => d.name);
            const values = chartData.map(d => d.y);
            const summaries = chartData.map(d => d.summary);

            const colors = chartData.map(p => {
                if (p.y >= 100) return '#4CAF50';
                else if (p.y >= 90) return '#F4A300';
                else return '#C00000';
            });

            // ---- Update HTML subtitle (fixed) ----
            $('#chart-subtitle').html(
                `Total Employee: ${data.totalemp} | ` +
                `Basic: ${data.grand_Basic.toFixed(2)}% | ` +
                `Education: ${data.grand_Education.toFixed(2)}% | ` +
                `Work: ${data.grand_Work.toFixed(2)}% | ` +
                `Overall: ${data.grand_Overall.toFixed(2)}%`
            );

            // ---- Remove old canvas and set dynamic width for scrolling ----
            $("#containerplant").html('<canvas id="plantChart"></canvas>');
            let canvasWidth = labels.length * 50; // 80px per bar
            $("#containerplant").css("min-width", canvasWidth + "px");

            const ctx = document.getElementById('plantChart');

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: "Overall Profile Completion (%)",
                        data: values,
                        backgroundColor: colors
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: { duration: 800 },

                    scales: {
                        x: {
                            ticks: {
                                maxRotation: 55,
                                minRotation: 55,
                                font: { size: 10, weight: 'bold' }
                            }
                        },
                        y: {
                            min: 0,
                            max: 100,
                            ticks: {
                                callback: val => val + "%",
                                font: { size: 12 }
                            },
                            title: {
                                display: true,
                                text: "Completion %"
                            }
                        }
                    },

                    plugins: {
                        legend: { display: false },

                        // Data labels
                        datalabels: {
                            anchor: 'end',
                            align: 'top',
                            formatter: value => value.toFixed(2) + "%",
                            color: '#000',
                            font: { size: 9, weight: 'bold' }
                        },

                        // Tooltip disabled (we use external HTML)
                        tooltip: { enabled: false }
                    },

                    // Click event
                    onClick: (evt, elements) => {
                        if (elements.length > 0) {
                            const index = elements[0].index;
                            const plantName = labels[index];
                            showPlantDetails(plantName);
                        }
                    }
                },

                plugins: [ChartDataLabels]
            });

            // ---- Custom HTML Tooltip ----
            const chart = Chart.getChart("plantChart");
            chart.options.plugins.tooltip.external = function(context) {

                const tooltipModel = context.tooltip;

                let tooltipEl = document.getElementById('chartjs-html-tooltip');
                if (!tooltipEl) {
                    tooltipEl = document.createElement('div');
                    tooltipEl.id = 'chartjs-html-tooltip';
                    tooltipEl.style.position = 'absolute';
                    tooltipEl.style.background = '#fff';
                    tooltipEl.style.border = '1px solid #ccc';
                    tooltipEl.style.padding = '8px 10px';
                    tooltipEl.style.borderRadius = '6px';
                    tooltipEl.style.boxShadow = '0px 2px 6px rgba(0,0,0,0.2)';
                    tooltipEl.style.pointerEvents = 'none';
                    tooltipEl.style.maxWidth = '400px'; // wider for long content
                    tooltipEl.style.fontSize = '12px';
                    document.body.appendChild(tooltipEl);
                }

                if (tooltipModel.opacity === 0) {
                    tooltipEl.style.opacity = 0;
                    return;
                }

                const dataIndex = tooltipModel.dataPoints[0].dataIndex;
                const label = tooltipModel.dataPoints[0].label;
                const value = tooltipModel.dataPoints[0].parsed.y;
                const color = tooltipModel.labelColors[0].backgroundColor;
                const summary = summaries[dataIndex];

                tooltipEl.innerHTML = `
                    <b>${label}</b><br>
                    <span style="color:${color}">●</span> <b>${value}%</b><br>
                    <hr style="margin:4px 0">
                    ${summary}
                `;


                tooltipEl.style.opacity = 1;

                // Get canvas position relative to viewport
                const canvasRect = context.chart.canvas.getBoundingClientRect();

                // Include page scroll offset so tooltip follows chart during scroll
                tooltipEl.style.left = window.scrollX + canvasRect.left + tooltipModel.caretX + 'px';
                tooltipEl.style.top = window.scrollY + canvasRect.top + tooltipModel.caretY + 'px';

            };
        },

        error: function (err) {
            console.error("Error fetching chart data:", err);
        }
    });
}




