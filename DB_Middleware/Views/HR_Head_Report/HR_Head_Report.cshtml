        function exportToExcel() {
            $('#loader').show();
                $.ajax({
                    url: '/HR_Head_Report/GetAjaySirReport',
                    type: 'POST',
                    data: {
                        length: 1000000, // Request large data
                        start: 0
                    },
                    success: function (response) {
                        $('#loader').hide();

                        var allData = response.data;

                        if (!allData || allData.length === 0) {
                            alert("No data available for export.");
                            return;
                        }

                        // These should match your JSON field names (not user-friendly headers)
                        var fields = [
                            'RequisitionId', 'GroupCompany', 'DepartmentName', 'BusinessUnitName',
                            'RequisitionRaisedByEmployeeId', 'RequisitionRaisedByEmployeeName',
                            'RequisitionStatus', 'RequisitionArchivedBy', 'RequisitionArchivedOn',
                            'RequisitionInitiatedOn', 'RequisitionActivatedOn', 'RequisitionActivatedBy',
