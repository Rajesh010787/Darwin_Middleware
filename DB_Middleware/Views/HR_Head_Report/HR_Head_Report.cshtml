                            'Level1ActionTakenBy', 'Level1ActionTakenOn', 'Level2Assignees',
                            'Level2Status', 'Level2ActionTakenBy', 'Level2ActionTakenOn',
                            'Level3Assignees', 'Level3Status', 'Level3ActionTakenBy', 'Level3ActionTakenOn',
                            'Level4Assignees', 'Level4Status', 'Level4ActionTakenBy', 'Level4ActionTakenOn',
                            'Level5Assignees', 'Level5Status', 'Level5ActionTakenBy', 'Level5ActionTakenOn',
                            'Level6Assignees', 'Level6Status', 'Level6ActionTakenBy', 'Level6ActionTakenOn',
                            'RequisitionLastApprovedRejectedOn', 'RequisitionLastApprovedRejectedBy',
                            'ReplacementEmployees', 'BudgetedNonBudgeted', 'VacancyDueTo',
                            'InternalTalent', 'HeadcountOfDepartmentBudget', 'HeadcountOfDepartmentActual',
                            'IfUnBudgetedReason', 'LevelAndDesignation', 'ExperienceRange',
                            'JustificationForHiring', 'OfferSection', 'CandidateName', 'DateOfApplication',
                            'CandidateSourceId', 'OfferEmployeeType', 'GeneratedBy', 'GeneratedOn',
                            'OfferSalaryStructureName', 'DateOfJoiningAsPerOffer', 'DateOfJoiningAsPerProfile',
                            'EmployeeId', 'OfferSentOn', 'OfferSentBy', 'OfferAcceptedOn', 'OfferAcceptedBy',
                            'CandidateCommentsInOfferLetter', 'OfferRejectedOn', 'OfferRejectedBy',
                            'OfferStatus', 'OfferWithdrawnOn', 'OfferWithdrawnBy', 'ExistingLevelAndDesignation',
                            'RevisedLevelAndDesignation', 'ExistingCostCentre', 'RevisedCostCentre',
                            'Level1AssigneesRepeat', 'Level1StatusRepeat', 'Level1ActionTakenByRepeat', 'Level1ActionTakenOnRepeat',
                            'Level2AssigneesRepeat', 'Level2StatusRepeat', 'Level2ActionTakenByRepeat', 'Level2ActionTakenOnRepeat'
                        ];

                        // Headers for Excel (user-friendly names)
                        var headers = [
                            'Requisition Id', 'Group Company', 'Department Name', 'Business Unit Name',
                            'Requisition Raised By - Employee Id', 'Requisition Raised By - Employee Name',
                            'Requisition Status', 'Requisition Archived By', 'Requisition Archived On',
                            'Requisition Initiated On', 'Requisition Activated On', 'Requisition Activated By',
                            'Requisition Hiring Manager', 'Level 1 Assignees', 'Level 1 Status',
                            'Level 1 Action Taken By', 'Level 1 Action Taken On', 'Level 2 Assignees',
                            'Level 2 Status', 'Level 2 Action Taken By', 'Level 2 Action Taken On',
                            'Level 3 Assignees', 'Level 3 Status', 'Level 3 Action Taken By', 'Level 3 Action Taken On',
                            'Level 4 Assignees', 'Level 4 Status', 'Level 4 Action Taken By', 'Level 4 Action Taken On',
                            'Level 5 Assignees', 'Level 5 Status', 'Level 5 Action Taken By', 'Level 5 Action Taken On',
                            'Level 6 Assignees', 'Level 6 Status', 'Level 6 Action Taken By', 'Level 6 Action Taken On',
                            'Requisition Last Approved / Rejected On', 'Requisition Last Approved / Rejected By',
                            'Replacement Employees', 'Budgeted / Non Budgeted', 'Vacancy Due To',
                            'Internal Talent: Can Anyone From Existing Team Take Up This Role? If Yes Then Who ?',
                            'Headcount Of Department - Budget', 'Headcount Of Department - Actual',
                            'If Un-Budgeted – Reason', 'Level And Designation', 'Experience Range (From – To)',
                            'Justification For Hiring (Why Not Internally - Associate To Staff, Or Clubbing Of Roles)',
                            'Offer Section', 'Candidate Name', 'Date Of Application', 'Candidate Source Id',
                            'Offer Employee Type', 'Generated By', 'Generated On', 'Offer Salary Structure Name',
                            'Date Of Joining As Per Offer', 'Date Of Joining As Per Profile', 'Employee Id',
                            'Offer Sent On', 'Offer Sent By', 'Offer Accepted On', 'Offer Accepted By',
                            'Candidate Comments In Offer Letter', 'Offer Rejected On', 'Offer Rejected By',
                            'Offer Status', 'Offer Withdrawn On', 'Offer Withdrawn By',
                            'Existing Level And Designation', 'Revised Level And Designation',
                            'Existing Cost Centre', 'Revised Cost Centre',
                            'Level 1 Assignees', 'Level 1 Status', 'Level 1 Action Taken By', 'Level 1 Action Taken On',
                            'Level 2 Assignees', 'Level 2 Status', 'Level 2 Action Taken By', 'Level 2 Action Taken On'
                        ];

                        // Map data using field names
                        var tableData = allData.map(function (item) {
                            return fields.map(function (field) {
                                return item[field] !== undefined ? item[field] : '';
                            });
                        });

                        var worksheetData = [headers, ...tableData];
                        var worksheet = XLSX.utils.aoa_to_sheet(worksheetData);
                        var workbook = XLSX.utils.book_new();
                        XLSX.utils.book_append_sheet(workbook, worksheet, "Full Report");

                        XLSX.writeFile(workbook, 'HR_Head_Report.xlsx');
                    },
                    error: function () {
                        $('#loader').hide();
                        alert("Error exporting data.");
                    }
