        $(document).ready(function () {
            const urlSearchParams = new URLSearchParams(window.location.search);
            const params = Object.fromEntries(urlSearchParams.entries());
            var cid = params['id'];
         
            Bindexicitingnewrecords(cid);

          
            //Binddomainname();
            //runDatePicker();
            //Bindgroupemail();
            /*  BindMSLicense();*/

        });
       

        function Bindexicitingnewrecords(pageCid) {
            $.ajax({
                url: "/Internal_Transfer/getactibGetemployeedetailsfordirecttransfer",
                type: "GET",
                data: { Uniquesid: pageCid.toString() },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                async: false,
                success: function (data) {
                    if (Array.isArray(data)) {
                        let newEmployee = null;
                        let existingEmployee = null;

                        // Separate new and existing employees
                        data.forEach(function (item) {
                            if (item.requestype === "New") {
                                newEmployee = item;
                            } else if (item.requestype === "Existing") {
                                existingEmployee = item;
                            }
                        });

                        // Fill fields and highlight mismatches
                        if (newEmployee) {
                            fillFields("#new", newEmployee);

                          


                        }
                        if (existingEmployee) {
                            fillFields("#Exicting", existingEmployee);
                        }

                        // Highlight mismatches between New and Existing fields
                        highlightMismatches(newEmployee, existingEmployee);
                    }
                }
            });

            function fillFields(prefix, employee) {
                $(prefix + "empcode").val(employee.employee_id);
                $(prefix + "fullname").val(employee.fname);
                $(prefix + "emailid").val(employee.company_email_id);
                $(prefix + "department").val(employee.department);
                $(prefix + "divisionvertical").val(employee.department_cost_center_name);
                $(prefix + "businessvertical").val(employee.group_company);
                $(prefix + "txtlocation").val(employee.office_location);
                $(prefix + "dateofjoining").val(employee.date_of_joining);


                $(prefix + "joblevel").val(employee.job_level);
                $(prefix + "mobilenumber").val(employee.office_mobile_no);
                $(prefix + "manageremail").val(employee.direct_manager_email);
                $(prefix + "manager").val(employee.direct_manager_name);

            }

            function highlightMismatches(newEmployee, existingEmployee) {
                if (!newEmployee || !existingEmployee) return;

                const fields = [
                    { id: "empcode", newValue: newEmployee.employee_id, existingValue: existingEmployee.employee_id },
                    { id: "fullname", newValue: newEmployee.fname, existingValue: existingEmployee.fname },
                    { id: "emailid", newValue: newEmployee.company_email_id, existingValue: existingEmployee.company_email_id },
                    { id: "department", newValue: newEmployee.department, existingValue: existingEmployee.department },
                    { id: "divisionvertical", newValue: newEmployee.department_cost_center_name, existingValue: existingEmployee.department_cost_center_name },
                    { id: "businessvertical", newValue: newEmployee.group_company, existingValue: existingEmployee.group_company },
                    { id: "txtlocation", newValue: newEmployee.office_location, existingValue: existingEmployee.office_location },
                    { id: "dateofjoining", newValue: newEmployee.dateofjoining, existingValue: existingEmployee.dateofjoining },

                    { id: "joblevel", newValue: newEmployee.job_level, existingValue: existingEmployee.job_level },
                    { id: "mobilenumber", newValue: newEmployee.office_mobile_no, existingValue: existingEmployee.office_mobile_no },
                    { id: "manageremail", newValue: newEmployee.direct_manager_email, existingValue: existingEmployee.direct_manager_email },
                    { id: "manager", newValue: newEmployee.direct_manager_name, existingValue: existingEmployee.direct_manager_name },
                ];

                fields.forEach(field => {
                    if (field.newValue !== field.existingValue) {
                        $(`#new${field.id}, #existing${field.id}`).addClass("highlight");
                    }
                });
            }
        }

        //-------------------------------get replace employeedetails------------------------

        function BindreplacementEmpdetails() {

            $.ajax({

                url: "/Email_Request/Bind_Repempdetails",
                type: "GET",
                data: { empid: "" + $("#txtreplaceecode").val() + "" },
                contentType: "application/json;charset=utf-8",
