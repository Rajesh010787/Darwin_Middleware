                    for (var index = 0; index < data.length; index++) {


                        $("#txtrepemployeename").val(data[index].fname);

                        $("#txtrepgradelevel").val(data[index].level_Grade);
                        $("#txtrepdesignation").val(data[index].job_level);
                        $("#txtexicitingemail").val(data[index].company_email_id);




                    }
                }
            });
        }

       
