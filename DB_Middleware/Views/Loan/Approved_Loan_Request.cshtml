    <script type='text/javascript'>
        var date = new Date();
        var year = date.getFullYear(); //get year
        var month = date.getMonth(); //get month
        var controls = {
            leftArrow: '<i class="fal fa-angle-left" style="font-size: 1.25rem"></i>',
            rightArrow: '<i class="fal fa-angle-right" style="font-size: 1.25rem"></i>'
        }
        var runDatePicker = function () {


            $("#txtconfrimjoiningdate").datepicker({
                dateFormat: 'dd-mm-yy' // Correct format for jQuery UI datepicker

            });

        }

        var totalList = [];
        var iterms = "";
        $(document).ready(function () {
            const urlSearchParams = new URLSearchParams(window.location.search);
            const params = Object.fromEntries(urlSearchParams.entries());
            var cid = params['id'];

            BindEmpdetailsforapprovelloandetails();


        });
        //------------------Bind Tracking History ---------------------------------------------


        function BindEmpdetailsforapprovelloandetails() {
            $.ajax({
                url: "/Loan/Get_Loan_Approved",
                type: "GET",
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    console.log("AJAX Data:", data); // Debug
                    console.log("Is Array?", Array.isArray(data));
                    console.log("Array Length:", data.length);

                    // Destroy existing DataTable if exists
                    if ($.fn.DataTable.isDataTable('#example1')) {
                        $('#example1').DataTable().clear().destroy();
                    }

                    // Handle empty or non-array data
                    if (!Array.isArray(data) || data.length === 0) {
                        $('#example1').html(
                            '<tr><td colspan="10" style="text-align:center;">No pending loans found</td></tr>'
                        );
                        return; // Stop execution, don't initialize DataTable
                    }

                    // Initialize DataTable with actual data
                    $('#example1').DataTable({
                        responsive: true,
                        processing: true,
                        data: data,
                        order: [[4, 'desc']],
                        autoWidth: false,
                        columns: [
                        
                            { data: 'gid', title: 'ID', width: '90px' },
                            { data: 'cStatus', title: 'Status', width: '90px' },
                            { data: 'deviation', title: 'Deviation', width: '30px' },
                          /*  { data: 'salarydown', title: 'Salary Drawn', width: '60px' },*/
                            { data: 'rupess', title: 'Rupees', width: '40px' },
                            { data: 'installments', title: 'Installments', width: '20px' },
                            { data: 'purpose', title: 'Purpose', width: '180px' },
                            { data: 'pending', title: 'Pending', width: '110px' },
                            { data: 'fullname', title: 'Created By', width: '110px' },
                            {
                                data: null,
                                title: 'Tracking',
                                width: '10px',
                                render: function (data, type, row) {
                                    return `<a style="text-decoration: none; color:black;"
                                        href="#"
                                        onclick='Bindloanhistory("${row.id}", "");'>
                                        <span class="badge badge-pill badge-success">View</span>
                                    </a>`;
                                }
                            },
                        ],
                        dom: 'Blfrtip',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                className: 'btn-outline-success btn-sm',
                                text: 'Export to Excel'
                            },
                            {
                                extend: 'csvHtml5',
                                className: 'btn-outline-primary btn-sm',
                                text: 'Export to CSV'
                            },
                            {
                                extend: 'copyHtml5',
                                className: 'btn-outline-success btn-sm',
                                text: 'Copy to Clipboard'
                            }
                        ],
                        language: {
                            emptyTable: "No pending loans to display"
                        }
                    });
                },
                error: function (xhr, status, error) {
                    console.error("AJAX Error: ", status, error);
                    $('#example1').html(
                        '<tr><td colspan="10" style="text-align:center; color:red;">Error loading data</td></tr>'
                    );
                }
            });
        }


        // Example function for the Edit button action
        function EditEmployee(userID) {
            // Implement the edit logic here, e.g., redirect to an edit page or open a modal
            console.log("Edit employee with ID:", userID);
        }


        //------------------Bind Tracking History ---------------------------------------------

       
        function Bindloanhistory(Eid) {
           /* $("#txtuniqueidhistoty").text(fullname);*/
            $('#modal-Tracking_history').modal('show');
            $.ajax({
                url: "/Loan/get_tracking_loan_records_history",
                type: "GET",
                data: { uniqueid: "" + Eid + ""},

                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    /*     console.log(data); // Log the data to inspect*/

                    if (Array.isArray(data) && data.length > 0) {
                        // Destroy the existing DataTable instance if it exists
                        if ($.fn.DataTable.isDataTable('#example2')) {
                            $('#example2').DataTable().clear().destroy();
                        }
                        // Initialize DataTable with new data
                        $('#example2').DataTable({
                            responsive: true,
                            processing: true,
                            async: true,
                            data: data,
                            order: [[4, 'desc']],

                            columns: [
                                { data: 'actionid', title: 'ID', width: '5%' },
                                { data: 'actionby', title: 'Action By', width: '20%' },
                                { data: 'peningon', title: 'Pending On', width: '20%' },
                                { data: 'cstatus', title: 'Action Status', width: '10%' },

                                { data: 'actiondate', title: 'Action Date', width: '10%', type: 'date' },
                                { data: 'remark', title: 'Remark', width: '40%' }

                            ]

                        });

                        // Handle click event on "Edit" link
                        $('#example2').on('click', '.edit-link', function (e) {
                            e.preventDefault();

                            // Replace the following line with your edit logic, e.g., opening a modal or redirecting
                            /* console.log('Edit button clicked for ID: ' + id);*/
                        });
                    } else {
                        console.error("No data found or data is not an array");
                    }
                },
                error: function (xhr, status, error) {
                    console.error("AJAX Error: ", status, error);
                }
            });
        }


    </script>

