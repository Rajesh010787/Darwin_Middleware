        function exportToExcel() {

            const urlSearchParams = new URLSearchParams(window.location.search);
            const params = Object.fromEntries(urlSearchParams.entries());
            var cid = params['id'];

            $.ajax({
                url: '/Loan/Get_Loan_Details_Export_InExcel',
                type: 'GET',
                data: { id: cid },

                success: function (response) {

                    var allData = response.data;

                    if (!allData || allData.length === 0) {
                        alert("No data available for export");
                        return;
                    }

                    var tableData = allData.map(function (item) {
                        return [
                            item.ecode,
                            item.fullname,
                            item.costcenter,
                            item.sapcostcenter,
                            item.prfofitcenter,
                            item.plant,
                            item.newcostcenter,
                            item.pan,
                            item.bankname,
                            item.ifsccode,
                            item.accountnumber,
                            item.finalamount,
                            item.sapecode
                        ];
                    });

                    var exportTable = $('<table>');

                    exportTable.append(`
                <thead>
                    <tr>
                        <th>Employee Code</th>
                        <th>Full Name</th>
                        <th>Cost Center</th>
                        <th>SAP Cost Center</th>
                        <th>Profit Center</th>
                        <th>Plant</th>
                        <th>New Cost Center</th>
                        <th>PAN</th>
                        <th>Bank Name</th>
                        <th>IFSC Code</th>
                        <th>Account Number</th>
                        <th>Amount</th>
                        <th>SAP ECode</th>
                    </tr>
                </thead>
            `);

                    var tbody = $('<tbody>');

                    tableData.forEach(function (row) {

                        var tr = $('<tr>');

                        row.forEach(function (cell) {
                            tr.append('<td>' + (cell ?? '') + '</td>');
                        });

                        tbody.append(tr);

                    });

                    exportTable.append(tbody);

                    var wb = XLSX.utils.table_to_book(exportTable[0], { sheet: "Loan Details Report" });

                    XLSX.writeFile(wb, 'Loan_Details_Report.xlsx');
                },

                error: function (error) {
                    console.log("Error exporting data:", error);
                }

            });
        }


