    <script src="~/js/formplugins/bootstrap-datepicker/bootstrap-datepicker.js"></script>
    <script src="~/js/jquery.min.js"></script>

    <script src="~/js/Action_JS/loanjs.js"></script>

    <script type='text/javascript'>


        var totalList = [];
        var iterms = "";

        $(document).ready(function () {
          

            if ("@loaneligibility" == "Completed 6 Months") {




                const urlSearchParams = new URLSearchParams(window.location.search);
                const params = Object.fromEntries(urlSearchParams.entries());
                const cid = params.id || "";
                Bindpurposemaster();
                $('.select2').select2();

                if (cid !== "") {
                    $("#btnsubmithrloancreation").text('Update');
                    bindLoanDetailsforedit(cid);
                    $("#hiddenuniqueid").val(cid);
                } else {
                    Bindgaranteepeoplesname1();
                    Bindgaranteepeoplesname2();
                }

                $("#dbgarantee1").on("change", function () {
                    filterDropdowns();
                });

                $("#dbgarantee2").on("change", function () {
                    filterDropdowns();
                });
            } else {


                window.location.href = '/Loan/Notification';
            }
        });

        const deviation = document.getElementById("dbdeviation");
        const installments = document.getElementById("txtinstallments");

        // Handle Deviation changes
        deviation.addEventListener("change", function () {
            if (this.value === "No") {
                installments.value = 10;
                installments.min = 10;
                installments.max = 10;
                installments.readOnly = true;
            }
            else if (this.value === "Yes") {
                installments.value = 10;
                installments.min = 10;
                installments.max = 24;
                installments.readOnly = false;
            }
            else {
                installments.value = "";
                installments.readOnly = false;
                installments.removeAttribute("min");
                installments.removeAttribute("max");
            }
        });

        // Validate only when user leaves the input (blur)
        installments.addEventListener("blur", function () {
            let val = parseInt(this.value, 10);

            if (isNaN(val)) {
                this.value = "";
                return;
            }

            // enforce min/max only here
            if (deviation.value === "Yes") {
                if (val < 10) this.value = 10;
                if (val > 24) this.value = 24;
            }
        });

        // Optional: prevent typing non-numeric characters
        installments.addEventListener("keypress", function (e) {
            if (!/[0-9]/.test(e.key)) {
                e.preventDefault();
            }
        });
        // Salary Down

        function convertToWordssalarydown(num) {
            num = num.replace(/[^0-9]/g, '');
            document.getElementById("txtsalarydown").value = num;

            if (num === "") {
                document.getElementById("amountWordssalarydown").innerHTML = "";
                return;
            }

            document.getElementById("amountWordssalarydown").innerHTML = numberToWordsIndian(num);
        }


        // Input Rupess
        function convertToWords(num) {
            num = num.replace(/[^0-9]/g, '');
            document.getElementById("txtrupess").value = num;

            if (num === "") {
                document.getElementById("amountWords").innerHTML = "";
                return;
            }

            document.getElementById("amountWords").innerHTML = numberToWordsIndian(num);
        }

        function numberToWordsIndian(num) {
            const a = [
                '', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine',
                'Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen',
                'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'
            ];
            const b = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];

            if ((num = num.toString()).length > 9) return 'Overflow';

            let n = ('000000000' + num).slice(-9).match(/(\d{2})(\d{2})(\d{2})(\d{1})(\d{2})/);
            if (!n) return '';

            let str = '';
            str += (n[1] != 0) ? (a[n[1]] || b[n[1][0]] + ' ' + a[n[1][1]]) + ' Crore ' : '';
            str += (n[2] != 0) ? (a[n[2]] || b[n[2][0]] + ' ' + a[n[2][1]]) + ' Lakh ' : '';
            str += (n[3] != 0) ? (a[n[3]] || b[n[3][0]] + ' ' + a[n[3][1]]) + ' Thousand ' : '';
            str += (n[4] != 0) ? (a[n[4]] || b[n[4][0]] + ' ' + a[n[4][1]]) + ' Hundred ' : '';
            str += (n[5] != 0) ? ((str != '') ? 'and ' : '') + (a[n[5]] || b[n[5][0]] + ' ' + a[n[5][1]]) + ' ' : '';

            return str.trim();
        }



        function Bindgaranteepeoplesname1() {


            $.ajax({

                url: "/Loan/Bind_Garanted_Person",
                type: "GET",
                async: false,
                data: { Ecode: @Empcode },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    var JsData = data;
                    var binddata = '<option value="">Select</option>';
                    for (var index = 0; index < JsData.length; index++) {
                        binddata = binddata + '<option value="' + JsData[index].gperson_Ecode + '" >' + JsData[index].gpersonname + '</option>';
                    }
                    $("#dbgarantee1").html(binddata);

                }
            });
        }
        function Bindgaranteepeoplesname2() {


            $.ajax({

                url: "/Loan/Bind_Garanted_Person",
                type: "GET",
                async: false,
                data: { Ecode: @Empcode },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    var JsData = data;
                    var binddata = '<option value="">Select</option>';
                    for (var index = 0; index < JsData.length; index++) {
                        binddata = binddata + '<option value="' + JsData[index].gperson_Ecode + '" >' + JsData[index].gpersonname + '</option>';
                    }
                    $("#dbgarantee2").html(binddata);

                }
            });
        }


           function Bindpurposemaster() {


            $.ajax({

                url: "/Loan/Bind_Purpose",
                type: "GET",
                async: false,
                data: {},
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    var JsData = data;
                    var binddata = '<option value="">Select</option>';
                    for (var index = 0; index < JsData.length; index++) {
                        binddata = binddata + '<option value="' + JsData[index].purpose + '" >' + JsData[index].purpose + '</option>';
                    }
                    $("#dbpurpos").html(binddata);

                }
            });
        }





        function Bindgaranteepeoplesnameedit1(garantee1) {


            $.ajax({

                url: "/Loan/Bind_Garanted_Person",
                type: "GET",
                async: false,
                data: { Ecode: @Empcode },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    var JsData = data;
                    var binddata = '<option value="">Select</option>';
                    for (var index = 0; index < JsData.length; index++) {
                        binddata = binddata + '<option value="' + JsData[index].gperson_Ecode + '" >' + JsData[index].gpersonname + '</option>';
                    }
                    $("#dbgarantee1").html(binddata);
                    $("#dbgarantee1").val(garantee1);
                }
            });
        }
        function Bindgaranteepeoplesnameedit2(garantee2) {


            $.ajax({

                url: "/Loan/Bind_Garanted_Person",
                type: "GET",
                async: false,
                data: { Ecode: @Empcode },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    var JsData = data;
                    var binddata = '<option value="">Select</option>';
                    for (var index = 0; index < JsData.length; index++) {
                        binddata = binddata + '<option value="' + JsData[index].gperson_Ecode + '" >' + JsData[index].gpersonname + '</option>';
                    }
                    $("#dbgarantee2").html(binddata);
                    $("#dbgarantee2").val(garantee2);

                }
            });
        }
        /* -------------------- VICE VERSA FILTER LOGIC -------------------- */
        function filterDropdowns() {

            var val1 = $("#dbgarantee1").val();
            var val2 = $("#dbgarantee2").val();

            // Reset all options
            $("#dbgarantee1 option, #dbgarantee2 option")
                .show()
                .prop("disabled", false);

            // Hide dbgarantee1 selection from dbgarantee2
            if (val1 !== "") {
                $("#dbgarantee2 option[value='" + val1 + "']")
                    .hide()
                    .prop("disabled", true);
            }

            // Hide dbgarantee2 selection from dbgarantee1
            if (val2 !== "") {
                $("#dbgarantee1 option[value='" + val2 + "']")
                    .hide()
                    .prop("disabled", true);
            }

            // Prevent same value selected in both
            if (val1 !== "" && val1 === val2) {
                $("#dbgarantee2").val("");
            }
        }



        function bindLoanDetailsforedit(uniqueId) {
            $.ajax({

                url: "/Loan/get_loandetails_details_for_validate",
                type: 'GET',
                data: { uniqueid: uniqueId },
                dataType: 'json',
                async: false,
                success: function (response) {

                    if (response.length > 0) {
                        var data = response[0];

                        $('#txtempcode').val(data.ecode);
                        $('#txtsalarydown').val(data.salarydown);

                        $('#txtdepartment').val(data.department);


                        $('#txtrupess').val(data.rupess);
                        filterDropdowns();




                        Bindgaranteepeoplesnameedit1(data.garanteesecode1);
                        Bindgaranteepeoplesnameedit2(data.garanteesecode2);




                        $('#tatpurpose').val(data.purpose);
                        $('#dbdeviation').val(data.deviation);

                        $('#txtname').val(data.fullname);


                        $('#txtinstallments').val(data.installments); // bind value
                        // Make read-only if needed

                        $('#txtbusinessvertical').val(data.businessvertical);
                        $('#txtdivision').val(data.division);
                        $('#txtplant').val(data.plant);

                    }
                    else {
                        alert('No loan details found.');
                    }
                },
                error: function () {
                    alert('Error while fetching loan details.');
                }
            });
        }

    </script>




</main>

