                                                <input type="text" class="form-control input-sm" id="txtdatejoin" autocomplete="off" name="txtdatejoin" value="@DOJ" disabled="disabled">

                                            </div>

                                        </div>
                                        <div class="form-row">

                                            <div class="col-md-3 mb-2">

                                                <label for="validationCustom02"> Salary Drawn to Basic + HRA</label><span class="text-danger">*</span>
                                                @*<input type="text" class="form-control input-sm" id="txtsalarydown" autocomplete="off" name="txtsalarydown">*@
                                                <input type="text"
                                                       class="form-control input-sm"
