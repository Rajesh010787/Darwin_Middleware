    <script type='text/javascript'>
        var totalList = [];
        var iterms = "";
        $(document).ready(function () {
            const urlSearchParams = new URLSearchParams(window.location.search);
            const params = Object.fromEntries(urlSearchParams.entries());
            var cid = params['id'];

            BindEmpdetailsforemail(cid);

        });
        function Redirect(id) {

                window.location.href = '/Email_Request/HR_Validate_New_Request?id=' + id;

        }
        function Bind_Records_For_NotJoined(id) {

            $('#modal-Tracking').modal('show');
            $.ajax({

                url: "/Email_Request/HR_Validate",
                type: "GET",
                data: { UniqueID: "" + id + "" },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                async: false,
                success: function (data) {

                    var build_table = '';
                    for (var index = 0; index < data.length; index++) {


                        $("#Firstname").val(data[index].fname);
                        $("#middlename").val(data[index].mname);
                        $("#lastname").val(data[index].lname);
                        $("#txtdeprtment").val(data[index].department);
                        $("#txtdesignation").val(data[index].deisgnation);
                        $("#txtgrade").val(data[index].level_Grade);

                        $("#txtuniqueid").text(data[index].userUniqueID);
                        $("#txtgroupname").val(data[index].group_company);
                        $("#txtfunctionalareadept").val(data[index].department_cost_center_name);



                    }
                }
            });

        }

        function BindEmpdetailsforemail(paageCid) {
            $.ajax({
                url: "/Visitor/get_pending_employee_emailid_creation",
                type: "GET",
                data: {
                    UniqueID: paageCid
                },
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                success: function (data) {
                    if (Array.isArray(data) && data.length > 0) {
                        // Destroy existing DataTable instance if it exists
                        if ($.fn.DataTable.isDataTable('#example1')) {
                            $('#example1').DataTable().clear().destroy();
                        }

                        // Initialize DataTable with new data
                        $('#example1').DataTable({
                            responsive: true,
                            processing: true,
                            data: data,
                            order: [[4, 'desc']],
                            columns: [
                                {
                                    data: null,
                                    title: 'Action',
                                    render: function (data, type, row) {
                                        const isChecked = row.visitor_Status === "1" ? "checked" : "";
                                        return `
                                    <input type="checkbox" class="employee-checkbox" id="${row.userUniqueID}" 
                                           data-uniqueid="${row.userUniqueID}"
                                           onclick='handleCheckboxClick(this, "${row.userUniqueID}");'
                                           ${isChecked} />`;
                                    }
                                },
                                { data: 'fname', title: 'First Name' },
                                { data: 'mname', title: 'Middle Name' },
                                { data: 'lname', title: 'Last Name' },
                                { data: 'date_of_joining', title: 'Date of Joining', type: 'date' },
                                { data: 'group_company', title: 'Group Company' },
                                { data: 'functional_area_dept', title: 'Functional Area(Dept)' },
                                { data: 'level_Grade', title: 'Grade' },
                                { data: 'direct_manager_name', title: 'RM' },
                                { data: 'hrbp_name', title: 'HRBP Name' },
                                { data: 'office_location', title: 'Office Location' },
                            ],
                            dom: 'Blfrtip',  // 'l' is kept to show the page size dropdown, 'p' is for pagination

                            buttons: [
                                {
                                    extend: 'excelHtml5',
                                    className: 'btn-outline-success btn-sm',  // Add custom classes to the Excel button
                                    text: 'Export to Excel'
                                },
                                {
                                    extend: 'csvHtml5',
                                    className: 'btn-outline-primary btn-sm',  // Add custom classes to the CSV button
                                    text: 'Export to CSV'
                                },
                                {
                                    extend: 'copyHtml5',
                                    className: 'btn-outline-success btn-sm',  // Add custom classes to the Copy button
                                    text: 'Copy to Clipboard'
                                }
                            ],
                        });
                    } else {
                        console.error("No data found or data is not an array");
                    }
                },
                error: function (xhr, status, error) {
                    console.error("AJAX Error: ", status, error);
                }
            });
        }

        // Function to handle checkbox clicks
        function handleCheckboxClick(checkbox, userUniqueID) {
            var result = confirm("Are you sure wants to update this records?");
            if (result == true) {

    // Get the checked state as a boolean
    const isChecked = checkbox.checked;

    // AJAX request
    $.ajax({
        url: '@Url.Action("SaveEmployeeStatus", "Visitor")',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ userUniqueID: userUniqueID, isChecked: isChecked }), // Send the boolean state

        success: function (response) {
            alert(response.message); // Optional: Feedback to user
        },
        error: function (xhr, status, error) {
            console.error("Error saving status:", status, error);
            alert("An error occurred while saving employee status.");
        }
    });
            } else {
                document.getElementById(userUniqueID).checked = false;
                return false;
            }
}


        // Example function for the Edit button action
        function EditEmployee(userID) {
